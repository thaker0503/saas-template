{
  "name": "acme-saas-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.5.0",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "turbo run format",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "db:dev:up": "docker compose -f docker/docker-compose.dev.yml up -d",
    "db:dev:down": "docker compose -f docker/docker-compose.dev.yml down -v",
    "db:migrate": "pnpm --filter @acme/api prisma:migrate",
    "db:seed": "pnpm --filter @acme/api prisma:seed",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,md,css,scss,json}": [
      "prettier --write"
    ],
    "**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "tsc -p tsconfig.base.json --noEmit --pretty false"
    ]
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@commitlint/cli": "^19.4.0",
    "@commitlint/config-conventional": "^19.4.0",
    "@types/node": "^20.12.14",
    "eslint": "^8.57.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "turbo": "^2.1.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  }
}